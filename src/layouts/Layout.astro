---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "OneMICE — Where MICE comes together",
  description = "OneMICE instaure le cadre qui manquait au MICE corporate. Une infrastructure pour unifier les flux, aligner les acteurs, piloter la complexité.",
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="/brand.css" />
  </head>
  <body>
    <slot />
  </body>
</html>
